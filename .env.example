EVENTS_JSON_URL=https://events.pdxhackerspace/events.json
# Optional ICS feed URL
EVENTS_ICS_URL=
POLL_INTERVAL_SECONDS=3600
REQUEST_TIMEOUT_SECONDS=30

QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=events
QDRANT_DISTANCE=Cosine

# ollama (default), onnx (requires pip install .[onnx]),
# or sentence-transformers (requires pip install .[torch])
EMBEDDING_BACKEND=ollama
EMBEDDING_MODEL_NAME=qllama/bge-small-en-v1.5
EMBEDDING_BATCH_SIZE=64
# Max tokens the embedding model accepts (512 for bge-small-en-v1.5)
EMBEDDING_CONTEXT_LENGTH=512

# Ollama endpoint (only used when EMBEDDING_BACKEND=ollama)
OLLAMA_URL=http://ollama:11434

ICS_LOOKBACK_DAYS=30
ICS_LOOKAHEAD_DAYS=365
LOG_LEVEL=INFO
